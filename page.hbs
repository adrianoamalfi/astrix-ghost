{{!< default}}

{{#post}}
<article class="gh-article {{post_class}}">

    {{#if @page.show_title_and_feature_image}}
        <header class="gh-article-header gh-article-header--page">
            {{> "breadcrumbs"}}

            <h1 class="gh-article-title">{{title}}</h1>
            {{#if custom_excerpt}}
                <p class="gh-article-excerpt">{{custom_excerpt}}</p>
            {{/if}}
        </header>

        {{#if feature_image}}
            <figure class="gh-article-image">
                <img
                    srcset="{{img_url feature_image size="m" format="webp"}} 640w,
                            {{img_url feature_image size="l" format="webp"}} 1024w,
                            {{img_url feature_image size="xl" format="webp"}} 1920w"
                    sizes="(max-width: 1600px) 100vw, 1600px"
                    src="{{img_url feature_image size="xl" format="webp"}}"
                    width="1920" height="1080"
                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                    decoding="async"
                    fetchpriority="high"
                >
            </figure>
        {{/if}}
    {{/if}}

    <section class="gh-content gh-canvas"
        data-copy="{{t "Copy"}}" data-copied="{{t "Copied"}}"
        data-anchor-label="{{t "Copy link to this section"}}"
        data-anchor-copied-label="{{t "Copied"}}"
        data-zoom-label="{{t "Zoom image"}}" data-close-label="{{t "Close"}}"
        data-prev-label="{{t "Previous"}}" data-next-label="{{t "Next"}}">
        {{content}}
    </section>

</article>
{{/post}}
