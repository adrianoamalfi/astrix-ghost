{{!< default}}

{{#author}}
<header class="gh-archive-header">
    <div class="gh-archive-inner">
        {{> "breadcrumbs"}}

        <div class="gh-author-header">
            {{#if profile_image}}
                <img class="gh-author-avatar" data-astryx-avatar="lg" src="{{img_url profile_image size="s" format="webp"}}" alt="{{name}}" loading="lazy" decoding="async">
            {{else}}
                <span class="gh-author-avatar gh-author-avatar--fallback" data-astryx-avatar="lg" aria-hidden="true">{{name}}</span>
            {{/if}}
            <div>
                <span class="u-kicker">{{t "Author"}}</span>
                <h1 class="gh-archive-title">{{name}}</h1>
                {{#if bio}}
                    <p class="gh-archive-description">{{bio}}</p>
                {{/if}}
                <div class="gh-author-links" data-astryx-overflow-list>
                    {{#if location}}<span class="gh-archive-meta">{{location}}</span>{{/if}}
                    {{#if website}}<a class="gh-tag-chip" href="{{website}}" target="_blank" rel="me noopener">{{t "Website"}}</a>{{/if}}
                    {{#if twitter}}<a class="gh-tag-chip" href="{{social_url type="twitter"}}" target="_blank" rel="me noopener">Twitter</a>{{/if}}
                    {{#if facebook}}<a class="gh-tag-chip" href="{{social_url type="facebook"}}" target="_blank" rel="me noopener">Facebook</a>{{/if}}
                </div>
            </div>
        </div>
    </div>
</header>
{{/author}}

<div class="gh-feed-wrap">
    <h2 class="u-visually-hidden">{{t "Latest posts"}}</h2>
    {{#if posts}}
        <div class="gh-feed gh-feed--bold-grid">
            {{#foreach posts}}
                {{> "post-card"}}
            {{/foreach}}
        </div>
    {{else}}
        {{> "empty-state"}}
    {{/if}}
</div>

{{pagination}}
