{{!< default}}

{{#author}}
<header class="gh-archive-header">
    <div class="gh-archive-inner">
        <div class="gh-author-header">
            {{#if profile_image}}
                <img class="gh-author-avatar" src="{{img_url profile_image size="s"}}" alt="{{name}}" loading="lazy" decoding="async">
            {{/if}}
            <div>
                <span class="u-kicker">{{t "Author"}}</span>
                <h1 class="gh-archive-title">{{name}}</h1>
                {{#if bio}}
                    <p class="gh-archive-description">{{bio}}</p>
                {{/if}}
                <div class="gh-author-links">
                    {{#if location}}<span class="gh-archive-meta">{{location}}</span>{{/if}}
                    {{#if website}}<a class="gh-tag-chip" href="{{website}}" target="_blank" rel="noopener">{{t "Website"}}</a>{{/if}}
                    {{#if twitter}}<a class="gh-tag-chip" href="{{social_url type="twitter"}}" target="_blank" rel="noopener">Twitter</a>{{/if}}
                    {{#if facebook}}<a class="gh-tag-chip" href="{{social_url type="facebook"}}" target="_blank" rel="noopener">Facebook</a>{{/if}}
                </div>
            </div>
        </div>
    </div>
</header>
{{/author}}

<div class="gh-feed-wrap">
    {{#if posts}}
        <div class="gh-feed gh-feed--bold-grid">
            {{#foreach posts}}
                {{> "post-card"}}
            {{/foreach}}
        </div>
    {{else}}
        {{> "empty-state"}}
    {{/if}}
</div>

{{pagination}}
