<!DOCTYPE html>
<html lang="{{@site.locale}}" data-astryx-theme="neutral"{{#match @custom.color_scheme_default "!=" "System"}} data-scheme-default="{{@custom.color_scheme_default}}"{{/match}}>
<head>
    {{!-- No-flash color scheme: must run before any CSS is applied --}}
    <script>(function () {
        try {
            var s = localStorage.getItem('astrix-scheme');
            if (!s) { s = (document.documentElement.getAttribute('data-scheme-default') || '').toLowerCase(); }
            if (s === 'dark' || s === 'light') { document.documentElement.style.colorScheme = s; }
        } catch (e) { /* storage unavailable */ }
    })();</script>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <title>{{meta_title}}</title>

    {{!-- Preload the primary Latin subset. Its @font-face is declared inline in
          the <style> below (not in fonts.css) so both reference the same
          {{asset}} URL — otherwise the version-hashed preload and a bare CSS
          url() would mismatch and the font would be downloaded twice. --}}
    <link rel="preload" href="{{asset "fonts/figtree-latin.woff2"}}" as="font" type="font/woff2" crossorigin>
    {{> "head-preload"}}
    <link rel="stylesheet" href="{{asset "built/screen.css"}}">
    {{#is "post, page"}}<link rel="stylesheet" href="{{asset "built/post.css"}}">{{/is}}

    {{!-- Warm up jsdelivr: Ghost serves Portal (~600KB) and sodo-search from
          cdn.jsdelivr.net, so open the DNS+TLS connection early. --}}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>

    {{!-- RSS feed discovery for feed readers and AI agents (Ghost does not emit this automatically) --}}
    <link rel="alternate" type="application/rss+xml" title="{{@site.title}}" href="{{@site.url}}/rss/">

    {{!-- If you load analytics via Ghost code injection, warm up its origin
          here (or via injection) to skip DNS+TLS setup on the first request:
          <link rel="preconnect" href="https://your-analytics-host"> --}}

    <style>
        /* Primary Latin subset, declared here (not in fonts.css) so its src goes
           through the asset helper and gets the same version-hashed URL as the
           preload above — matching URLs mean the preloaded font is reused
           instead of fetched twice. The other subsets stay in fonts.css.
           NB: Handlebars parses this file in full, CSS comments included, so
           never write a bare helper call in here — it would be evaluated. */
        @font-face {
            font-family: 'Figtree';
            font-style: normal;
            font-weight: 300 900;
            font-display: swap;
            {{!-- Triple-stache: inside <style> HTML entities are not decoded, so
                  an escaped "=" in the ?v= query would break the URL. --}}
            src: url("{{{asset "fonts/figtree-latin.woff2"}}}") format("woff2");
            unicode-range:
                U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329,
                U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
        }

        :root {
            {{#if @custom.secondary_accent}}--gh-accent-2: {{@custom.secondary_accent}};{{/if}}
        }

        /* Cross-document view transitions: feature images morph between the
           card/hero and the post (progressive enhancement; unsupported
           browsers ignore it). Kept out of the layered stylesheets because
           it applies to navigation, not to component styling. */
        @media (prefers-reduced-motion: no-preference) {
            @view-transition {
                navigation: auto;
            }
        }

        /* Without an explicit background the transition overlay falls back
           to the UA canvas, which meta color-scheme "light dark" + a dark
           system resolve to DARK even when the reader chose light — the
           mid-animation dark flash. The token follows the effective scheme. */
        ::view-transition {
            background-color: var(--color-background-body);
        }
    </style>

    {{ghost_head}}
</head>
<body class="{{body_class}}">

    <a class="gh-skip-link" href="#gh-main-content">{{t "Skip to content"}}</a>

    {{> "site-header"}}

    <main id="gh-main-content" class="gh-main">
        {{{body}}}
    </main>

    {{> "site-footer"}}

    <button class="gh-back-to-top" type="button" aria-label="{{t "Back to top"}}" hidden>
        {{> "icons/arrow-up"}}
    </button>

    <script defer src="{{asset "built/main.js"}}"></script>
    {{ghost_foot}}
</body>
</html>
