# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Zero Trust → Networks → Tunnels → Create a tunnel → Docker → copy the token.
# Keep this secret: .env is gitignored, never commit it.
TUNNEL_TOKEN=

# ── Public URLs ──────────────────────────────────────────────────────────────
# Must match exactly the Public Hostnames you map in the Cloudflare dashboard.
# Ghost renders absolute links and image URLs from these values.
#
# In the dashboard, point each hostname at the container by name:
#   <your hostname>  →  http://meridian:2368   (and vellum / proof / fieldnotes)
MERIDIAN_URL=https://meridian.example.com
VELLUM_URL=https://vellum.example.com
PROOF_URL=https://proof.example.com
FIELDNOTES_URL=https://fieldnotes.example.com
