# Which demo publication to seed on first run:
#   meridian (travel · Poster hero, Mosaic feed)
#   vellum   (design · Editorial hero, Bold grid)
#   proof    (food   · Split hero, List feed, membership)
#   fieldnotes (personal · Personal hero)
DEMO=meridian

# Port on the host
PORT=8080

# Public URL Ghost renders links and images with.
# Local:  http://localhost:8080
# Live:   https://demo.example.com
GHOST_URL=http://localhost:8080

# Ghost env. `production` is the default; use `development` if your host
# has no MySQL and Ghost complains about SQLite.
GHOST_ENV=production
