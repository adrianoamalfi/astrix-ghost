{{!-- Empty archive state. Context: a collection page with no posts. --}}
<div class="gh-empty">
    <span class="gh-empty-icon" aria-hidden="true">{{> "icons/search"}}</span>
    <p class="gh-empty-title">{{t "Nothing here yet"}}</p>
    <p class="gh-empty-text">{{t "There are no posts to show right now. Check back soon."}}</p>
    <a class="gh-button gh-button--ghost" href="{{@site.url}}">{{t "Back to home"}}</a>
</div>
