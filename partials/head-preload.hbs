{{!-- Preload the LCP feature image so it is discovered in <head> instead of
      mid-body, shaving the request off the critical path. Mirrors the srcset
      and sizes of the hero/feature image element so the browser preloads the
      exact candidate it will render. --}}
{{!-- Preload AVIF to match the picture source the browser will pick. The type
      hint means browsers without AVIF support skip this preload and discover
      the WebP image in the body instead (a small, shrinking cohort). --}}
{{#is "post"}}{{#post}}{{#if feature_image}}
    <link rel="preload" as="image" fetchpriority="high" type="image/avif"
        href="{{img_url feature_image size="xl" format="avif"}}"
        imagesrcset="{{img_url feature_image size="m" format="avif"}} 640w, {{img_url feature_image size="l" format="avif"}} 1024w, {{img_url feature_image size="xl" format="avif"}} 1920w, {{img_url feature_image size="xxl" format="avif"}} 2400w"
        imagesizes="(max-width: 1600px) 100vw, 1600px">
{{/if}}{{/post}}{{/is}}
{{#is "page"}}{{#post}}{{#if @page.show_title_and_feature_image}}{{#if feature_image}}
    <link rel="preload" as="image" fetchpriority="high" type="image/avif"
        href="{{img_url feature_image size="xl" format="avif"}}"
        imagesrcset="{{img_url feature_image size="m" format="avif"}} 640w, {{img_url feature_image size="l" format="avif"}} 1024w, {{img_url feature_image size="xl" format="avif"}} 1920w"
        imagesizes="(max-width: 1600px) 100vw, 1600px">
{{/if}}{{/if}}{{/post}}{{/is}}
{{!-- Homepage LCP. Which element that is depends on @custom.header_style: the
      Personal portrait when one is set, otherwise the first featured post's
      feature_image (via post-hero, or the first post-card in the Personal
      slider). Each branch mirrors the srcset/sizes of the element it actually
      renders, so the browser preloads the exact candidate it will paint — a
      mismatch would cost an extra download instead of saving one. The
      {{#if feature_image}} guard skips the text-only intro shown when there
      are no featured posts. --}}
{{#is "home"}}
{{!-- Personal style renders the author portrait above everything else, so when
      one is set it — not the featured image — is the LCP. It does not depend on
      the featured posts, hence its own block outside the {{#get}} below. --}}
{{#match @custom.header_style "Personal"}}{{#if @custom.personal_hero_portrait}}
    <link rel="preload" as="image" fetchpriority="high" type="image/avif"
        href="{{img_url @custom.personal_hero_portrait size="l" format="avif"}}"
        imagesrcset="{{img_url @custom.personal_hero_portrait size="m" format="avif"}} 640w, {{img_url @custom.personal_hero_portrait size="l" format="avif"}} 1024w"
        imagesizes="(max-width: 900px) 60vw, 420px">
{{/if}}{{/match}}
{{#get "posts" filter="featured:true" limit="1" as |featured|}}{{#foreach featured}}{{#if feature_image}}
    {{#match @custom.header_style "Personal"}}
    {{!-- Only when no portrait claimed the LCP above. --}}
    {{#unless @custom.personal_hero_portrait}}
    <link rel="preload" as="image" fetchpriority="high" type="image/avif"
        href="{{img_url feature_image size="l" format="avif"}}"
        imagesrcset="{{img_url feature_image size="s" format="avif"}} 320w, {{img_url feature_image size="m" format="avif"}} 640w, {{img_url feature_image size="l" format="avif"}} 1024w"
        imagesizes="(max-width: 640px) 92vw, (max-width: 1000px) 46vw, 420px">
    {{/unless}}
    {{else match @custom.header_style "Editorial"}}
    <link rel="preload" as="image" fetchpriority="high" type="image/avif"
        href="{{img_url feature_image size="xl" format="avif"}}"
        imagesrcset="{{img_url feature_image size="m" format="avif"}} 640w, {{img_url feature_image size="l" format="avif"}} 1024w, {{img_url feature_image size="xl" format="avif"}} 1920w"
        imagesizes="(max-width: 1600px) 100vw, 1600px">
    {{else match @custom.header_style "Split"}}
    <link rel="preload" as="image" fetchpriority="high" type="image/avif"
        href="{{img_url feature_image size="l" format="avif"}}"
        imagesrcset="{{img_url feature_image size="m" format="avif"}} 640w, {{img_url feature_image size="l" format="avif"}} 1024w, {{img_url feature_image size="xl" format="avif"}} 1920w"
        imagesizes="(max-width: 900px) 100vw, 50vw">
    {{else}}
    <link rel="preload" as="image" fetchpriority="high" type="image/avif"
        href="{{img_url feature_image size="xl" format="avif"}}"
        imagesrcset="{{img_url feature_image size="m" format="avif"}} 640w, {{img_url feature_image size="l" format="avif"}} 1024w, {{img_url feature_image size="xl" format="avif"}} 1920w, {{img_url feature_image size="xxl" format="avif"}} 2400w"
        imagesizes="100vw">
    {{/match}}
{{/if}}{{/foreach}}{{/get}}{{/is}}
