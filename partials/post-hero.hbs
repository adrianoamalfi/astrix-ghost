{{!-- Home hero. Context: a post object. Variant comes from
      @custom.header_style: Poster (full-bleed, always-dark scrimmed image),
      Editorial (contained, text above image) or Split (text | image). --}}
{{#match @custom.header_style "Editorial"}}

<section class="gh-hero gh-hero--editorial">
    <div class="gh-hero-content">
        <div class="gh-hero-content-inner">
            {{#primary_tag}}
                <a class="gh-hero-tag" href="{{url}}">{{name}}</a>
            {{/primary_tag}}
            <h1 class="gh-hero-title"><a href="{{url}}">{{title}}</a></h1>
            {{#if custom_excerpt}}
                <p class="gh-hero-excerpt">{{custom_excerpt}}</p>
            {{else}}
                <p class="gh-hero-excerpt">{{excerpt words="40"}}</p>
            {{/if}}
            <div class="gh-hero-meta">
                {{#primary_author}}
                    <span class="gh-meta-author">
                        {{#if profile_image}}
                            <img class="gh-meta-author-avatar" src="{{img_url profile_image size="s"}}" alt="{{name}}" loading="lazy" decoding="async">
                        {{/if}}
                        <span>{{name}}</span>
                    </span>
                {{/primary_author}}
                <span aria-hidden="true">·</span>
                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMM YYYY"}}</time>
                <span aria-hidden="true">·</span>
                <span>{{reading_time}}</span>
            </div>
        </div>
    </div>
    {{#if feature_image}}
        <a class="gh-hero-editorial-media" href="{{url}}">
            <img
                srcset="{{img_url feature_image size="m"}} 640w,
                        {{img_url feature_image size="l"}} 1024w,
                        {{img_url feature_image size="xl"}} 1920w"
                sizes="(max-width: 1600px) 100vw, 1600px"
                src="{{img_url feature_image size="xl"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                decoding="async"
                fetchpriority="high"
            >
        </a>
    {{/if}}
</section>

{{else match @custom.header_style "Split"}}

<section class="gh-hero gh-hero--split">
    <div class="gh-hero-split-text">
        {{#primary_tag}}
            <a class="gh-hero-tag" href="{{url}}">{{name}}</a>
        {{/primary_tag}}
        <h1 class="gh-hero-title"><a href="{{url}}">{{title}}</a></h1>
        {{#if custom_excerpt}}
            <p class="gh-hero-excerpt">{{custom_excerpt}}</p>
        {{else}}
            <p class="gh-hero-excerpt">{{excerpt words="32"}}</p>
        {{/if}}
        <div class="gh-hero-meta">
            {{#primary_author}}
                <span class="gh-meta-author">
                    {{#if profile_image}}
                        <img class="gh-meta-author-avatar" src="{{img_url profile_image size="s"}}" alt="{{name}}" loading="lazy" decoding="async">
                    {{/if}}
                    <span>{{name}}</span>
                </span>
            {{/primary_author}}
            <span aria-hidden="true">·</span>
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMM YYYY"}}</time>
            <span aria-hidden="true">·</span>
            <span>{{reading_time}}</span>
        </div>
    </div>
    {{#if feature_image}}
        <a class="gh-hero-split-media" href="{{url}}">
            <img
                srcset="{{img_url feature_image size="m"}} 640w,
                        {{img_url feature_image size="l"}} 1024w,
                        {{img_url feature_image size="xl"}} 1920w"
                sizes="(max-width: 900px) 100vw, 50vw"
                src="{{img_url feature_image size="l"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                decoding="async"
                fetchpriority="high"
            >
        </a>
    {{/if}}
</section>

{{else}}

<section class="gh-hero gh-hero--poster{{#unless feature_image}} gh-hero--no-image{{/unless}}" data-astryx-media="dark">
    {{#if feature_image}}
        <div class="gh-hero-media">
            <img
                srcset="{{img_url feature_image size="m"}} 640w,
                        {{img_url feature_image size="l"}} 1024w,
                        {{img_url feature_image size="xl"}} 1920w,
                        {{img_url feature_image size="xxl"}} 2400w"
                sizes="100vw"
                src="{{img_url feature_image size="xl"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                decoding="async"
                fetchpriority="high"
            >
        </div>
        <div class="gh-hero-scrim"></div>
    {{/if}}

    <div class="gh-hero-content">
        <div class="gh-hero-content-inner">
            {{#primary_tag}}
                <a class="gh-hero-tag" href="{{url}}">{{name}}</a>
            {{/primary_tag}}

            <h1 class="gh-hero-title"><a href="{{url}}">{{title}}</a></h1>

            {{#if custom_excerpt}}
                <p class="gh-hero-excerpt">{{custom_excerpt}}</p>
            {{else}}
                <p class="gh-hero-excerpt">{{excerpt words="40"}}</p>
            {{/if}}

            <div class="gh-hero-meta">
                {{#primary_author}}
                    <span class="gh-meta-author">
                        {{#if profile_image}}
                            <img class="gh-meta-author-avatar" src="{{img_url profile_image size="s"}}" alt="{{name}}" loading="lazy" decoding="async">
                        {{/if}}
                        <span>{{name}}</span>
                    </span>
                {{/primary_author}}
                <span aria-hidden="true">·</span>
                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMM YYYY"}}</time>
                <span aria-hidden="true">·</span>
                <span>{{reading_time}}</span>
            </div>
        </div>
    </div>
</section>

{{/match}}
