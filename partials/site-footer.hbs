<footer class="gh-footer">
    <div class="gh-footer-inner">
        <div class="gh-footer-main">
            <div class="gh-footer-identity">
                <a class="gh-footer-brand" href="{{@site.url}}">{{@site.title}}</a>
                {{#if @site.description}}
                    <p class="gh-footer-bio">{{@site.description}}</p>
                {{/if}}
                {{> "social-links"}}
            </div>

            {{#if @site.secondary_navigation}}
                <nav class="gh-footer-nav" aria-label="{{t "Secondary navigation"}}">
                    {{navigation type="secondary"}}
                </nav>
            {{/if}}
        </div>

        <div class="gh-footer-meta">
            <span class="gh-footer-copyright">&copy; {{date format="YYYY"}} {{@site.title}}</span>
            <div class="gh-footer-credits">
                <span>{{t "Theme"}} <a href="https://adrianoamalfi.com/astrix/" target="_blank" rel="noopener noreferrer">Astrix</a></span>
                <span class="gh-footer-sep" aria-hidden="true">&middot;</span>
                <span>{{t "Published with"}} <a href="https://ghost.org" target="_blank" rel="noopener noreferrer">Ghost</a></span>
            </div>
        </div>
    </div>
</footer>
