{{!< default}}

{{#post}}
<article class="gh-article {{post_class}}">
    <header class="gh-article-header gh-article-header--page">
        <span class="u-kicker">{{t "Membership"}}</span>
        <h1 class="gh-article-title">{{title}}</h1>
        {{#if custom_excerpt}}
            <p class="gh-article-excerpt">{{custom_excerpt}}</p>
        {{/if}}
    </header>

    {{#if content}}
        <section class="gh-content gh-canvas">
            {{content}}
        </section>
    {{/if}}
</article>
{{/post}}

{{#get "tiers" filter="type:paid" include="monthly_price,yearly_price,benefits" limit="6" as |tiers|}}
    {{#if tiers}}
        <section class="gh-tiers">
            {{#foreach tiers}}
                <div class="gh-tier">
                    <h2 class="gh-tier-name">{{name}}</h2>
                    {{#if description}}
                        <p class="gh-tier-description">{{description}}</p>
                    {{/if}}
                    {{#if monthly_price}}
                        <div class="gh-tier-price">
                            <span class="gh-tier-amount">{{price monthly_price currency=currency}}</span>
                            <span class="gh-tier-period">/ {{t "month"}}</span>
                        </div>
                    {{else}}
                        {{#if yearly_price}}
                            <div class="gh-tier-price">
                                <span class="gh-tier-amount">{{price yearly_price currency=currency}}</span>
                                <span class="gh-tier-period">/ {{t "year"}}</span>
                            </div>
                        {{/if}}
                    {{/if}}
                    {{#if benefits}}
                        <ul class="gh-tier-benefits">
                            {{#foreach benefits}}
                                <li>{{this}}</li>
                            {{/foreach}}
                        </ul>
                    {{/if}}
                    {{#if monthly_price}}
                        <a class="gh-button" href="#/portal/signup/{{id}}/monthly" data-portal="signup/{{id}}/monthly">{{t "Choose this plan"}}</a>
                    {{else}}
                        <a class="gh-button" href="#/portal/signup/{{id}}/yearly" data-portal="signup/{{id}}/yearly">{{t "Choose this plan"}}</a>
                    {{/if}}
                </div>
            {{/foreach}}
        </section>
    {{/if}}
{{/get}}

{{> "subscribe-form"}}
