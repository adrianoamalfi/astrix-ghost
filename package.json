{
  "name": "astrix",
  "description": "A bold, expressive personal blog theme for Ghost, built on the Astryx design system tokens.",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Adriano Amalfi",
    "email": "adrianoamalfi@gmail.com",
    "url": "https://github.com/adrianoamalfi"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adrianoamalfi/astrix-ghost.git"
  },
  "bugs": "https://github.com/adrianoamalfi/astrix-ghost/issues",
  "homepage": "https://github.com/adrianoamalfi/astrix-ghost",
  "keywords": [
    "ghost",
    "ghost-theme"
  ],
  "engines": {
    "ghost": ">=6.0.0"
  },
  "config": {
    "posts_per_page": 12,
    "image_sizes": {
      "s": {
        "width": 320
      },
      "m": {
        "width": 640
      },
      "l": {
        "width": 1024
      },
      "xl": {
        "width": 1920
      },
      "xxl": {
        "width": 2400
      }
    },
    "card_assets": true,
    "custom": {
      "navigation_layout": {
        "type": "select",
        "options": [
          "Logo on the left",
          "Logo in the middle"
        ],
        "default": "Logo on the left"
      },
      "color_scheme_default": {
        "type": "select",
        "options": [
          "System",
          "Light",
          "Dark"
        ],
        "default": "System"
      },
      "secondary_accent": {
        "type": "color",
        "default": "#f5b301"
      },
      "header_style": {
        "type": "select",
        "options": [
          "Editorial",
          "Poster",
          "Split",
          "Personal"
        ],
        "default": "Poster",
        "group": "homepage"
      },
      "personal_hero_headline": {
        "type": "text",
        "default": "",
        "group": "homepage",
        "description": "Headline of the Personal hero. Leave empty to use the site title."
      },
      "personal_hero_text": {
        "type": "text",
        "default": "",
        "group": "homepage",
        "description": "Short bio shown in the Personal hero. Leave empty to use the site description."
      },
      "personal_hero_portrait": {
        "type": "image",
        "group": "homepage",
        "description": "Portrait photo for the Personal hero. Leave empty for a text-only hero."
      },
      "show_author_meta": {
        "type": "boolean",
        "default": true,
        "group": "homepage",
        "description": "Show author name and avatar on post cards and the homepage hero. Turn off on single-author blogs."
      },
      "social_github": {
        "type": "text",
        "default": "",
        "description": "GitHub username. Shown as an icon next to the Ghost social accounts."
      },
      "social_huggingface": {
        "type": "text",
        "default": "",
        "description": "Hugging Face username. Shown as an icon next to the Ghost social accounts."
      },
      "social_email": {
        "type": "text",
        "default": "",
        "description": "Public contact email. Shown as a mail icon next to the social accounts."
      },
      "social_custom_url": {
        "type": "text",
        "default": "",
        "description": "Full URL of one extra profile (Kaggle, Medium, Telegram, Scholar…). Shown with a globe icon."
      },
      "feed_layout": {
        "type": "select",
        "options": [
          "Bold grid",
          "Mosaic",
          "List"
        ],
        "default": "Bold grid",
        "group": "homepage"
      },
      "show_featured_slider": {
        "type": "boolean",
        "default": true,
        "group": "homepage"
      },
      "cta_headline": {
        "type": "text",
        "default": "",
        "group": "homepage",
        "description": "Headline of the subscribe call-to-action band. Leave empty for the default text."
      },
      "cta_text": {
        "type": "text",
        "default": "",
        "group": "homepage",
        "description": "Supporting text of the subscribe call-to-action band."
      },
      "show_toc": {
        "type": "boolean",
        "default": true,
        "group": "post"
      },
      "show_reading_progress": {
        "type": "boolean",
        "default": true,
        "group": "post"
      },
      "show_related_posts": {
        "type": "boolean",
        "default": true,
        "group": "post"
      }
    }
  },
  "scripts": {
    "tokens": "node scripts/extract-tokens.mjs",
    "build:css": "postcss assets/css/screen.css assets/css/post.css --dir assets/built",
    "build:js": "esbuild assets/js/main.js --bundle --minify --target=es2020 --outfile=assets/built/main.js",
    "build": "npm run tokens && npm run build:css && npm run build:js",
    "dev:css": "postcss assets/css/screen.css assets/css/post.css --dir assets/built --watch",
    "dev:js": "esbuild assets/js/main.js --bundle --sourcemap --target=es2020 --outfile=assets/built/main.js --watch",
    "dev:sync": "browser-sync start --proxy localhost:2368 --files \"assets/built/*\" \"**/*.hbs\" --no-open --no-notify",
    "dev": "npm run tokens && concurrently -n css,js,sync \"npm:dev:css\" \"npm:dev:js\" \"npm:dev:sync\"",
    "test": "gscan .",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:a11y": "node scripts/check-a11y.mjs",
    "check": "npm run build && npm test && npm run check:i18n && npm run check:a11y",
    "smoke": "node scripts/smoke-routes.mjs",
    "zip": "npm run check && mkdir -p dist && rm -f dist/astrix.zip && zip -r dist/astrix.zip . -x \"node_modules/*\" \"dist/*\" \"scripts/*\" \"assets/css/*\" \"assets/js/*\" \".git/*\" \".claude/*\" \"AGENTS.md\" \"VISUAL_QA.md\" \"PRODUCT.md\" \"DESIGN.md\" \".impeccable/*\" \".github/*\" \"docs/*\" \"demo/*\" \"CONTRIBUTING.md\" \"CODE_OF_CONDUCT.md\" \"SECURITY.md\" \"CHANGELOG.md\" \"postcss.config.cjs\" \"package-lock.json\" \"*.map\" \".DS_Store\" \"*/.DS_Store\" \".gitignore\"",
    "release": "npm run zip && node scripts/release-summary.mjs"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.3",
    "@astryxdesign/core": "^0.1.3",
    "@astryxdesign/theme-neutral": "^0.1.3",
    "browser-sync": "^3.0.3",
    "concurrently": "^9.1.2",
    "cssnano": "^7.0.6",
    "esbuild": "^0.25.5",
    "gscan": "^6.4.1",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0"
  }
}
